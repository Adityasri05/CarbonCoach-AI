rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for common validation
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidString(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }

    function isValidOptionalString(val, maxLen) {
      return val == null || (val is string && val.size() <= maxLen);
    }

    function isValidNumber(val, minVal, maxVal) {
      return val is number && val >= minVal && val <= maxVal;
    }

    function isValidInt(val, minVal, maxVal) {
      return val is int && val >= minVal && val <= maxVal;
    }

    function isValidBool(val) {
      return val is bool;
    }

    // User profiles — only the authenticated owner can read/write their own data
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserCreate(request.resource.data);
      allow update: if isOwner(userId) && isValidUserUpdate(resource.data, request.resource.data);
      allow delete: if isOwner(userId);

      // Subcollections under user (habits, challenges, scans)
      // Restrict subcollection paths specifically rather than wildcarding all
      match /habits/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidHabits(request.resource.data);
      }
      match /challenges/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidChallenge(request.resource.data);
      }
      match /scans/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidScan(request.resource.data);
      }
    }

    // Leaderboard — authenticated users can read, only owner can write
    match /leaderboard/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() 
        && request.auth.uid == request.resource.data.userId 
        && isValidLeaderboardEntry(request.resource.data);
      allow update: if isAuthenticated() 
        && request.auth.uid == resource.data.userId 
        && request.auth.uid == request.resource.data.userId
        && isValidLeaderboardEntry(request.resource.data);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Global config (read-only for authenticated users)
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation functions for User
    function isValidUserCreate(data) {
      return data.keys().hasAny(['name', 'email'])
        && isValidString(data.name, 1, 100)
        && isValidString(data.email, 5, 254)
        && (!('age' in data) || isValidOptionalString(data.age, 10))
        && (!('country' in data) || isValidString(data.country, 1, 100))
        && (!('occupation' in data) || isValidOptionalString(data.occupation, 100))
        && (!('onboarded' in data) || isValidBool(data.onboarded))
        && (!('greenPoints' in data) || isValidInt(data.greenPoints, 0, 10000000))
        && (!('xp' in data) || isValidInt(data.xp, 0, 10000000))
        && (!('level' in data) || isValidInt(data.level, 1, 1000))
        && (!('streak' in data) || isValidInt(data.streak, 0, 10000))
        && (!('createdAt' in data) || data.createdAt is string)
        && (!('habits' in data) || data.habits is map);
    }

    function isValidUserUpdate(oldData, newData) {
      return isValidUserCreate(newData)
        && oldData.email == newData.email; // Cannot change email for security
    }

    // Validation functions for Leaderboard
    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['userId', 'name', 'avatar', 'reduction', 'points'])
        && data.userId is string
        && isValidString(data.name, 1, 100)
        && isValidString(data.avatar, 0, 1000)
        && isValidNumber(data.reduction, 0, 100)
        && isValidInt(data.points, 0, 10000000);
    }

    // Validation functions for habits, challenges, scans
    function isValidHabits(data) {
      return data.keys().hasOnly(['travelDistance', 'vehicleType', 'fuelType', 'electricityBill', 'acUsage', 'appliances', 'foodHabit', 'shoppingFrequency', 'recyclingHabits'])
        && data.travelDistance is number
        && data.vehicleType is string
        && data.fuelType is string
        && data.electricityBill is number
        && data.acUsage is number
        && data.appliances is list
        && data.foodHabit is string
        && data.shoppingFrequency is string
        && data.recyclingHabits is string;
    }

    function isValidChallenge(data) {
      return data.keys().hasOnly(['id', 'title', 'description', 'points', 'progress', 'daysTotal', 'daysCompleted', 'status', 'category'])
        && data.id is string
        && data.title is string
        && data.description is string
        && data.points is int
        && data.progress is int
        && data.daysTotal is int
        && data.daysCompleted is int
        && data.status is string
        && data.category is string;
    }

    function isValidScan(data) {
      return data.keys().hasOnly(['id', 'item', 'category', 'emission', 'alternative', 'altName', 'reduction', 'imageUrl', 'timestamp'])
        && data.id is string
        && data.item is string
        && data.category is string
        && data.emission is number
        && data.alternative is number
        && data.altName is string
        && data.reduction is number
        && data.imageUrl is string
        && (data.timestamp is string || data.timestamp is timestamp);
    }
  }
}
